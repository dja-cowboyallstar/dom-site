---
import Base from '~/layouts/Base.astro';
import Masthead from '~/components/Masthead.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

const entries = (await getCollection('writing'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---
<Base
  title="Writing | Dominick Amirr"
  description="Essays and notes on agents, finance systems, and the slow work of building software that ties out."
>
  <main class="page">
    <Masthead showHomeLink={true} />

    <article class="content">
      <header class="page-header">
        <h1>Writing</h1>
        <p class="dek">Notes on agents, finance systems, and the slow work of building software that ties out.</p>
      </header>

      {entries.length === 0 ? (
        <p class="empty">First piece publishing soon.</p>
      ) : (
        <ul class="writing-list">
          {entries.map((entry) => (
            <li>
              <a href={`/writing/${entry.id}`}>
                {entry.data.draft && <span class="draft-flag">Draft</span>}
                <h2>{entry.data.title}</h2>
                <p>{entry.data.description}</p>
                <time datetime={entry.data.pubDate.toISOString()}>
                  {entry.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                </time>
              </a>
            </li>
          ))}
        </ul>
      )}

      <p class="back-link"><a href="/">← Back to home</a></p>
    </article>
  </main>
</Base>

<style>
  .page-header { margin-bottom: 4rem; }

  .page-header h1 {
    font-family: var(--display);
    font-size: clamp(3rem, 5vw, 4rem);
    line-height: 1;
    letter-spacing: -0.022em;
    margin-bottom: 1rem;
  }

  .dek {
    font-family: var(--display);
    font-style: italic;
    font-size: clamp(1.2rem, 1.8vw, 1.4rem);
    color: var(--ink-soft);
    line-height: 1.4;
    max-width: 36rem;
  }

  .writing-list {
    list-style: none;
  }

  .writing-list li {
    border-bottom: 1px solid var(--rule-soft);
  }

  .writing-list li:last-child { border-bottom: none; }

  .writing-list a {
    display: block;
    padding: 1.75rem 0;
    background-image: none;
    position: relative;
  }

  .writing-list a:hover h2 { color: var(--accent); }

  .writing-list h2 {
    font-family: var(--display);
    font-size: 1.5rem;
    margin-bottom: 0.4rem;
    transition: color 0.2s ease;
  }

  .writing-list p {
    color: var(--ink-soft);
    font-size: 0.95rem;
    margin-bottom: 0.6rem;
    max-width: 36rem;
  }

  .writing-list time {
    font-family: var(--mono);
    font-size: 0.625rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }

  .draft-flag {
    position: absolute;
    top: 1.85rem;
    right: 0;
    font-family: var(--mono);
    font-size: 0.575rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 0.15rem 0.45rem;
    border-radius: 2px;
  }

  .empty {
    color: var(--ink-mute);
    font-style: italic;
    padding: 2rem 0;
  }

  .back-link {
    margin-top: 5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule);
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
</style>
