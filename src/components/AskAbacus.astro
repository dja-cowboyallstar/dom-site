---
const examples = [
  "Show me unbilled receivables on capital projects, only past contract milestone.",
  "Top 5 customers by AR aging over 60 days.",
  "Accrued purchases last quarter by department, with GL tie-out.",
  "Where did this $43k swing in COGS come from?",
];
---
<section class="ask-abacus" aria-labelledby="ask-heading">
  <header class="section-head">
    <span class="title" id="ask-heading">Ask Abacus</span>
    <span class="meta">Live demo</span>
  </header>

  <p class="intro">
    Type a controller-grade question. The model returns a SuiteQL query
    against NetSuite and a one-line explanation of how it got there. Same
    pattern Abacus uses in production, miniaturized for a personal site.
  </p>

  <form id="ask-form" class="prompt">
    <label for="ask-input" class="visually-hidden">Your question</label>
    <textarea
      id="ask-input"
      name="question"
      rows="1"
      placeholder="e.g. show me unbilled receivables on capital projects…"
      autocomplete="off"
      spellcheck="false"
    ></textarea>
    <button type="submit" id="ask-submit" aria-label="Ask">
      <span class="label">Ask</span>
      <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 8h10M9 4l4 4-4 4"/>
      </svg>
    </button>
  </form>

  <div class="examples">
    <span class="examples-label">Try:</span>
    <ul>
      {examples.map((ex) => (
        <li><button type="button" class="example" data-q={ex}>{ex}</button></li>
      ))}
    </ul>
  </div>

  <div id="ask-output" class="output" aria-live="polite" hidden>
    <div class="echo" id="ask-echo"></div>
    <div class="response" id="ask-response"></div>
  </div>

  <p class="disclaimer">
    Illustrative SuiteQL. Verify table and field names against your own NetSuite Records Browser before running.
  </p>
</section>

<script>
  const form = document.getElementById('ask-form') as HTMLFormElement;
  const input = document.getElementById('ask-input') as HTMLTextAreaElement;
  const submit = document.getElementById('ask-submit') as HTMLButtonElement;
  const output = document.getElementById('ask-output') as HTMLDivElement;
  const echo = document.getElementById('ask-echo') as HTMLDivElement;
  const response = document.getElementById('ask-response') as HTMLDivElement;
  const exampleBtns = document.querySelectorAll<HTMLButtonElement>('.example');

  // Auto-resize textarea
  const autosize = () => {
    input.style.height = 'auto';
    input.style.height = `${Math.min(input.scrollHeight, 240)}px`;
  };
  input?.addEventListener('input', autosize);

  // Cmd/Ctrl+Enter submits
  input?.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') {
      e.preventDefault();
      form?.requestSubmit();
    }
  });

  // Quick-fill from example
  exampleBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      input.value = btn.dataset.q || '';
      autosize();
      input.focus();
    });
  });

  // Render markdown-like content (codeblocks + bold + breaks) without a full md parser
  const render = (text: string) => {
    // Escape HTML
    const esc = (s: string) => s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');
    // Code fences
    const out = esc(text)
      .replace(/```(\w+)?\n([\s\S]*?)```/g, (_m, lang, code) => `<pre data-lang="${lang || ''}"><code>${code.trim()}</code></pre>`)
      .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
      .replace(/`([^`]+)`/g, '<code>$1</code>')
      .replace(/\n\n/g, '</p><p>')
      .replace(/\n/g, '<br/>');
    return `<p>${out}</p>`;
  };

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const q = input.value.trim();
    if (!q) return;

    submit.disabled = true;
    submit.classList.add('loading');
    output.hidden = false;
    echo.textContent = q;
    response.innerHTML = '<span class="thinking">Composing query…</span>';

    try {
      const res = await fetch('/api/ask-abacus', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ question: q }),
      });

      if (!res.ok || !res.body) {
        const err = await res.text().catch(() => '');
        response.innerHTML = `<p class="error">Couldn't reach the model${err ? `: ${err}` : '.'}</p>`;
        return;
      }

      const reader = res.body.getReader();
      const decoder = new TextDecoder();
      let acc = '';
      response.innerHTML = '';

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        acc += decoder.decode(value, { stream: true });
        response.innerHTML = render(acc);
      }
    } catch (err) {
      response.innerHTML = `<p class="error">Network error. Try again.</p>`;
    } finally {
      submit.disabled = false;
      submit.classList.remove('loading');
    }
  });
</script>

<style>
  .ask-abacus { margin-bottom: 5rem; }

  .intro {
    margin-bottom: 1.75rem;
    color: var(--ink-soft);
    max-width: 36rem;
  }

  /* Prompt input */
  .prompt {
    display: flex;
    gap: 0;
    align-items: stretch;
    border: 1px solid var(--rule);
    border-radius: 6px;
    background: var(--bg-shade);
    transition: border-color 0.2s ease;
    overflow: hidden;
  }

  .prompt:focus-within {
    border-color: var(--accent);
  }

  textarea {
    flex: 1;
    border: 0;
    outline: 0;
    padding: 0.95rem 1.1rem;
    background: transparent;
    color: var(--ink);
    resize: none;
    font-family: var(--body);
    font-size: 0.95rem;
    line-height: 1.5;
    min-height: 3rem;
  }

  textarea::placeholder {
    color: var(--ink-mute);
    font-style: italic;
  }

  #ask-submit {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0 1.1rem;
    background: var(--ink);
    color: var(--bg);
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-radius: 0;
    transition: background 0.2s ease, color 0.2s ease;
  }

  #ask-submit:hover:not(:disabled) {
    background: var(--accent);
  }

  #ask-submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  #ask-submit.loading .label::after {
    content: '…';
  }

  /* Examples */
  .examples {
    margin-top: 0.85rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.6rem;
    align-items: baseline;
  }

  .examples-label {
    font-family: var(--mono);
    font-size: 0.625rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }

  .examples ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.5rem;
  }

  .example {
    font-family: var(--body);
    font-size: 0.78rem;
    color: var(--ink-soft);
    padding: 0.3rem 0.65rem;
    border: 1px solid var(--rule);
    border-radius: 999px;
    transition: all 0.2s ease;
  }

  .example:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  /* Output */
  .output {
    margin-top: 2.25rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule);
  }

  .echo {
    font-family: var(--display);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--accent);
    margin-bottom: 1.4rem;
    padding-left: 1rem;
    border-left: 2px solid var(--accent);
    line-height: 1.4;
  }

  .response {
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--ink);
  }

  .response :global(p) {
    margin-bottom: 1rem;
  }

  .response :global(pre) {
    background: var(--bg-shade);
    border: 1px solid var(--rule-soft);
    border-radius: 4px;
    padding: 1rem 1.1rem;
    overflow-x: auto;
    font-family: var(--mono);
    font-size: 0.8rem;
    line-height: 1.55;
    margin: 1rem 0;
    color: var(--ink);
  }

  .response :global(code) {
    font-family: var(--mono);
    font-size: 0.85em;
    background: var(--bg-shade);
    padding: 0.1em 0.3em;
    border-radius: 3px;
  }

  .response :global(pre code) {
    background: transparent;
    padding: 0;
  }

  .response :global(strong) {
    font-weight: 500;
    color: var(--ink);
  }

  .response :global(.thinking) {
    color: var(--ink-mute);
    font-style: italic;
    animation: pulse 1.4s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.5; }
    50%      { opacity: 1; }
  }

  .response :global(.error) {
    color: var(--accent);
  }

  .disclaimer {
    margin-top: 1rem;
    font-family: var(--mono);
    font-size: 0.625rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-mute);
    max-width: 36rem;
  }

  .visually-hidden {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 600px) {
    .prompt {
      flex-direction: column;
    }
    #ask-submit {
      padding: 0.7rem 1rem;
      justify-content: center;
      border-radius: 0;
    }
    .response :global(pre) {
      font-size: 0.68rem;
      padding: 0.75rem;
      max-width: calc(100vw - 3rem);
    }
    .echo {
      font-size: 0.95rem;
    }
    .examples ul {
      gap: 0.35rem;
    }
    .example {
      font-size: 0.7rem;
      padding: 0.25rem 0.5rem;
    }
  }
</style>
