---
export interface Props {
  fig: string;
  caption: string;
}
const { fig, caption } = Astro.props;
---
<figure class="specimen">
  <div class="frame"><slot /></div>
  <figcaption>
    <span class="num">{fig}</span>
    <span class="desc">{caption}</span>
  </figcaption>
</figure>

<style>
  .specimen {
    margin-top: 1.75rem;
  }

  .frame {
    border: 1px solid var(--rule);
    border-radius: 6px;
    overflow: hidden;
    background: var(--bg-shade);
    aspect-ratio: 16 / 10;
    position: relative;
  }

  .frame :global(video),
  .frame :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  figcaption {
    margin-top: 0.85rem;
    font-family: var(--mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mute);
    display: flex;
    gap: 0.85rem;
    align-items: baseline;
  }

  .num { color: var(--ink-soft); font-weight: 500; }
  .desc { flex: 1; }
</style>
