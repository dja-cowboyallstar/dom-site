---
import { SUGGESTED_QUESTIONS, FOLLOW_UPS } from '~/lib/dom-qa';
---
<div class="ask-dom" id="ask-dom">
  <button class="ask-dom-trigger" id="ask-dom-trigger" aria-label="Learn more about Dom"
    onclick="document.getElementById('ask-dom-panel').hidden=false;this.classList.add('open');document.getElementById('ask-dom-input')?.focus()">
    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
    </svg>
  </button>

  <div class="ask-dom-panel" id="ask-dom-panel" hidden>
    <div class="panel-header">
      <span class="panel-title">Learn more about Dom</span>
      <button class="panel-close" id="ask-dom-close" type="button" aria-label="Close"
        onclick="document.getElementById('ask-dom-panel').hidden=true;document.getElementById('ask-dom-trigger').classList.remove('open')">
        <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" style="pointer-events:none;">
          <path d="M4 4l8 8M12 4l-8 8"/>
        </svg>
      </button>
    </div>
    <div class="panel-messages" id="ask-dom-messages">
      <div class="msg assistant">
        <p>Hey — ask me anything about Dom. Here are some good starting points:</p>
      </div>
      <div class="suggestions" id="ask-dom-suggestions">
        {SUGGESTED_QUESTIONS.map((q) => (
          <button type="button" class="suggestion" data-q={q}>{q}</button>
        ))}
      </div>
    </div>
    <form class="panel-input" id="ask-dom-form">
      <textarea
        id="ask-dom-input"
        rows="1"
        placeholder="Ask a question..."
        autocomplete="off"
        spellcheck="false"
      ></textarea>
      <button type="submit" id="ask-dom-submit" aria-label="Send">
        <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 8h10M9 4l4 4-4 4"/>
        </svg>
      </button>
    </form>
  </div>
</div>

<script define:vars={{ suggestionsData: JSON.stringify(SUGGESTED_QUESTIONS), followUpsData: JSON.stringify(FOLLOW_UPS) }}>
  window.__domQA = {
    suggestions: JSON.parse(suggestionsData),
    followUps: JSON.parse(followUpsData),
  };
</script>

<script>
  function initAskDom() {
    const form = document.getElementById('ask-dom-form') as HTMLFormElement;
    const input = document.getElementById('ask-dom-input') as HTMLTextAreaElement;
    const submit = document.getElementById('ask-dom-submit') as HTMLButtonElement;
    const messagesEl = document.getElementById('ask-dom-messages') as HTMLDivElement;
    const suggestionsEl = document.getElementById('ask-dom-suggestions') as HTMLDivElement;

    if (!form || !messagesEl) return;

    const qa = (window as any).__domQA;
    let history: Array<{ role: string; content: string }> = [];

    // ─── Detect current page section ────────────────
    function getPageSection(): string | undefined {
      const sections = document.querySelectorAll('section[id]');
      let current: string | undefined;
      for (const section of sections) {
        const rect = section.getBoundingClientRect();
        if (rect.top <= window.innerHeight / 2) {
          current = section.id;
        }
      }
      return current;
    }

    // ─── Markdown renderer ──────────────────────────
    function renderMarkdown(text: string): string {
      const esc = (s: string) =>
        s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

      const inline = (s: string) =>
        s
          .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
          .replace(/\*(.+?)\*/g, '<em>$1</em>')
          .replace(/`([^`]+)`/g, '<code>$1</code>');

      const blocks = text.split(/\n{2,}/);

      return blocks
        .map((block) => {
          const trimmed = block.trim();
          if (!trimmed) return '';

          const lines = trimmed.split('\n');

          if (lines.every((l) => /^[-•*]\s/.test(l.trim()) || !l.trim())) {
            const items = lines
              .filter((l) => l.trim())
              .map((l) => `<li>${inline(esc(l.replace(/^[-•*]\s+/, '')))}</li>`)
              .join('');
            return `<ul>${items}</ul>`;
          }

          if (lines.every((l) => /^\d+\.\s/.test(l.trim()) || !l.trim())) {
            const items = lines
              .filter((l) => l.trim())
              .map((l) => `<li>${inline(esc(l.replace(/^\d+\.\s+/, '')))}</li>`)
              .join('');
            return `<ol>${items}</ol>`;
          }

          return `<p>${inline(esc(trimmed).replace(/\n/g, '<br/>'))}</p>`;
        })
        .filter(Boolean)
        .join('');
    }

    // ─── Show follow-up suggestions ─────────────────
    function showFollowUps(category?: string) {
      const questions = category && qa.followUps[category]
        ? qa.followUps[category]
        : qa.suggestions.slice(0, 2);

      const container = document.createElement('div');
      container.className = 'suggestions';
      questions.forEach((q: string) => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'suggestion';
        btn.textContent = q;
        btn.addEventListener('click', () => ask(q));
        container.appendChild(btn);
      });
      messagesEl.appendChild(container);
      messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    // ─── Stream from Claude API ─────────────────────
    async function streamFromAPI(bubble: HTMLDivElement, q: string): Promise<string> {
      history.push({ role: 'user', content: q });

      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          messages: history,
          pageSection: getPageSection(),
        }),
      });

      if (!res.ok || !res.body) {
        const answer = "I couldn't process that right now. Try asking about Dom's background, projects, or skills.";
        bubble.innerHTML = renderMarkdown(answer);
        return answer;
      }

      const reader = res.body.getReader();
      const decoder = new TextDecoder();
      let acc = '';

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        acc += decoder.decode(value, { stream: true });
        bubble.innerHTML = renderMarkdown(acc);
        messagesEl.scrollTop = messagesEl.scrollHeight;
      }

      history.push({ role: 'assistant', content: acc });
      return acc;
    }

    // ─── Handle question ────────────────────────────
    async function ask(q: string) {
      if (suggestionsEl) suggestionsEl.hidden = true;

      // Remove any existing follow-up suggestions
      messagesEl.querySelectorAll('.suggestions:not(#ask-dom-suggestions)').forEach((el) => el.remove());

      // User bubble
      const userBubble = document.createElement('div');
      userBubble.className = 'msg user';
      userBubble.innerHTML = renderMarkdown(q);
      messagesEl.appendChild(userBubble);

      input.value = '';
      input.style.height = 'auto';
      submit.disabled = true;
      messagesEl.scrollTop = messagesEl.scrollHeight;

      // Assistant bubble
      const asstBubble = document.createElement('div');
      asstBubble.className = 'msg assistant';
      asstBubble.innerHTML = '<p class="thinking">...</p>';
      messagesEl.appendChild(asstBubble);
      messagesEl.scrollTop = messagesEl.scrollHeight;

      await new Promise((r) => setTimeout(r, 250));

      await streamFromAPI(asstBubble, q);
      showFollowUps();

      submit.disabled = false;
    }

    // ─── Auto-resize ────────────────────────────────
    input?.addEventListener('input', () => {
      input.style.height = 'auto';
      input.style.height = `${Math.min(input.scrollHeight, 120)}px`;
    });

    input?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        form.requestSubmit();
      }
    });

    // Escape to close
    document.addEventListener('keydown', (e) => {
      const panel = document.getElementById('ask-dom-panel');
      const trigger = document.getElementById('ask-dom-trigger');
      if (e.key === 'Escape' && panel && !panel.hidden) {
        panel.hidden = true;
        trigger?.classList.remove('open');
      }
    });

    // Suggestion clicks
    suggestionsEl?.querySelectorAll<HTMLButtonElement>('.suggestion').forEach((btn) => {
      btn.addEventListener('click', () => ask(btn.dataset.q || btn.textContent || ''));
    });

    // Form submit
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const q = input.value.trim();
      if (!q) return;
      ask(q);
    });
  }

  initAskDom();
  document.addEventListener('astro:after-swap', initAskDom);
</script>

<style>
  .ask-dom {
    position: fixed;
    bottom: 1.25rem;
    right: 1.25rem;
    z-index: 90;
    font-family: var(--body);
  }

  .ask-dom-trigger {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--accent);
    color: var(--bg);
    display: grid;
    place-items: center;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    cursor: pointer;
  }

  .ask-dom-trigger:hover {
    transform: scale(1.06);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.2);
  }

  .ask-dom-trigger.open {
    opacity: 0;
    pointer-events: none;
  }

  .ask-dom-panel {
    position: fixed;
    bottom: 5rem;
    right: 1.25rem;
    width: 380px;
    max-height: 70vh;
    background: var(--bg);
    border: 1px solid var(--rule);
    border-radius: 10px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .ask-dom-panel[hidden] {
    display: none;
  }

  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--rule-soft);
  }

  .panel-title {
    font-family: var(--mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }

  .panel-close {
    color: var(--ink-mute);
    padding: 0.5rem;
    cursor: pointer;
    min-width: 32px;
    min-height: 32px;
    display: grid;
    place-items: center;
  }

  .panel-close:hover { color: var(--accent); }

  .panel-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-height: 200px;
    max-height: calc(70vh - 7rem);
  }

  .msg {
    max-width: 85%;
    font-size: 0.82rem;
    line-height: 1.45;
  }

  .msg p { margin: 0; }
  .msg p + p { margin-top: 0.35rem; }

  .msg ul, .msg ol {
    margin: 0.25rem 0;
    padding-left: 1.1rem;
  }

  .msg p + ul, .msg p + ol { margin-top: 0.3rem; }
  .msg ul + p, .msg ol + p { margin-top: 0.3rem; }

  .msg li {
    margin-bottom: 0.18rem;
    line-height: 1.4;
  }

  .msg :global(code) {
    font-family: var(--mono);
    font-size: 0.82em;
    background: rgba(0,0,0,0.06);
    padding: 0.1em 0.35em;
    border-radius: 3px;
  }

  .msg.user {
    align-self: flex-end;
    background: var(--accent);
    color: var(--bg);
    border-radius: 12px 12px 2px 12px;
    padding: 0.5rem 0.8rem;
  }

  .msg.assistant {
    align-self: flex-start;
    background: var(--bg-shade);
    color: var(--ink);
    border-radius: 12px 12px 12px 2px;
    padding: 0.5rem 0.8rem;
  }

  .msg :global(strong) { font-weight: 600; }

  .msg .thinking {
    color: var(--ink-mute);
    animation: pulse 1.4s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 1; }
  }

  .suggestions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-self: flex-start;
  }

  .suggestion {
    font-family: var(--body);
    font-size: 0.78rem;
    color: var(--ink-soft);
    padding: 0.35rem 0.7rem;
    border: 1px solid var(--rule);
    border-radius: 999px;
    cursor: pointer;
    transition: all 0.2s ease;
    background: none;
  }

  .suggestion:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .panel-input {
    display: flex;
    align-items: stretch;
    border-top: 1px solid var(--rule-soft);
    background: var(--bg-shade);
  }

  .panel-input textarea {
    flex: 1;
    border: 0;
    outline: 0;
    padding: 0.75rem 0.85rem;
    background: transparent;
    color: var(--ink);
    resize: none;
    font-family: var(--body);
    font-size: 0.88rem;
    line-height: 1.5;
    min-height: 2.5rem;
  }

  .panel-input textarea::placeholder {
    color: var(--ink-mute);
  }

  #ask-dom-submit {
    padding: 0 0.85rem;
    color: var(--ink-mute);
    cursor: pointer;
    transition: color 0.2s ease;
  }

  #ask-dom-submit:hover:not(:disabled) { color: var(--accent); }
  #ask-dom-submit:disabled { opacity: 0.4; cursor: not-allowed; }

  @media (max-width: 480px) {
    .ask-dom-panel {
      width: calc(100vw - 2rem);
      right: 1rem;
      bottom: 4.5rem;
      max-height: 60vh;
    }
  }

  @media print {
    .ask-dom { display: none; }
  }
</style>
